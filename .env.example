# ============================================================
#  agentic-trade — example environment config
#  Copy to .env and fill in real values.
# ============================================================

# ----- Exchange API Keys ------------------------------------
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

HYPERLIQUID_API_KEY=your_hyperliquid_wallet_private_key
HYPERLIQUID_ACCOUNT_ADDRESS=your_wallet_address

# ----- LLM (AI agent, macro regime, sentiment classifier) ---
# Use either ANTHROPIC_API_KEY for the official API, or LLM_API_KEY +
# LLM_BASE_URL to point at an Anthropic-compatible proxy (Z.AI, OpenRouter...).
# LLM_API_KEY takes precedence when both are set.
ANTHROPIC_API_KEY=your_anthropic_api_key
# LLM_API_KEY=
# LLM_BASE_URL=https://api.z.ai/api/anthropic
LLM_MODEL=claude-sonnet-4-6

# ----- News / Sentiment -------------------------------------
TAVILY_API_KEY=your_tavily_api_key
# Optional backup key used when the primary rate-limits or errors.
# TAVILY_API_KEY_BACKUP=

# ----- Trading ----------------------------------------------
TRADING_PAIRS=BTC/USDT,ETH/USDT
DEFAULT_EXCHANGE=hyperliquid

# Per-trade risk as % of balance.
RISK_PER_TRADE_PCT=2.0
# Kill-switch: stop trading when drawdown from persisted peak exceeds this %.
MAX_DRAWDOWN_PCT=10.0
# Total notional exposure cap, expressed as fraction of balance (0.5 = 50%).
MAX_TOTAL_EXPOSURE=0.5
# Minimum combined-signal confidence to take a trade.
MIN_CONFIDENCE=0.7

# Position count / direction limits
MAX_POSITIONS=2
MAX_SAME_DIRECTION=2
# Correlated-asset cap: BTC/ETH/SOL share a cluster, DOGE/PEPE/WIF share one, etc.
MAX_PER_CLUSTER=1

# Notional per trade (in USDT).
MIN_TRADE_SIZE_USDT=10.0
MAX_TRADE_SIZE_USDT=50.0

# ----- Backtest realism knobs -------------------------------
# Slippage applied symmetrically (buys pay up, sells take down), bps of price.
SLIPPAGE_BPS=5.0
# Taker fee per side, bps of notional. Hyperliquid taker ≈ 5 bps.
FEE_BPS=5.0

# ----- Signal blending --------------------------------------
# Weight of sentiment in the final combined signal. Keep low — keyword/LLM
# sentiment is noisy and should nudge, not drive, trades.
SENTIMENT_WEIGHT=0.15

# ----- AI veto discipline (Phase 2) -------------------------
# Combined signal (tech × sentiment × alpha × regime) is the PRIMARY
# direction/confidence source. AI decisions are ADVISORY: they can only
# override the signal (HOLD or flip direction) when AI confidence is
# at least AI_VETO_MIN_CONFIDENCE. Below that threshold, AI is informational
# only. Raise toward 1.0 to tighten AI influence; 1.0 fully disables veto.
AI_VETO_MIN_CONFIDENCE=0.80

# ----- Tavily budget guardrails (Phase 3) -------------------
# Free plan is 2000 credits/month. Cache hits TTL for 90 min; circuit
# breaker stops hitting Tavily when monthly usage >= threshold
# (default 1800, leaving 10% headroom for unexpected spikes).
TAVILY_TTL_SECONDS=5400
TAVILY_MONTHLY_BUDGET=2000
TAVILY_CIRCUIT_THRESHOLD=1800

# ----- Key-levels engine (Phase 4) --------------------------
# Higher-TF pivots (prev quarter mid, weekly H/M/L, Monday bar, daily open,
# prev month high, etc.) feed a bounded ±1 bias score into the combined
# signal. LEVELS_WEIGHT controls how strongly they nudge; 0.0 disables.
LEVELS_ENABLED=true
LEVELS_WEIGHT=0.10
LEVELS_DAILY_HISTORY=200

# ----- Chop / mean-reversion engine (Phase 5) ---------------
# Fires ONLY in sideways regimes when the trend blend holds. Trades Donchian
# edges with RSI + ADX gates. CHOP_SIZE_MULT shrinks notional vs trend
# trades because win rate is structurally lower.
CHOP_ENABLED=true
CHOP_MIN_STRENGTH=0.55
CHOP_SIZE_MULT=0.5

# ----- Funding-rate filter (Hyperliquid perps) --------------
# Annualized thresholds: if funding is ADVERSE to the trade direction and
# exceeds these levels, size is halved (extreme) or the trade is skipped (skip).
# Hyperliquid reports per-hour funding; we annualize via × 24 × 365.
FUNDING_ENABLED=true
FUNDING_EXTREME_ANNUAL=0.30
FUNDING_SKIP_ANNUAL=0.60

# ----- Volatility-targeting sizing --------------------------
# When enabled, notional = (balance × TARGET_DAILY_VOL_PCT%) ÷ daily realized vol,
# falling back to ATR sizing if vol can't be estimated. Keeps expected daily
# P&L roughly constant across high- and low-vol symbols.
VOL_TARGET_ENABLED=true
TARGET_DAILY_VOL_PCT=1.0


# ----- Telegram (Phase 6) -----------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Cycle digest cadence — compact per-N-cycles rollup. Default 12 cycles
# = hourly at 5-minute intervals. Set 0 to mute the digest entirely.
TELEGRAM_DIGEST_INTERVAL_CYCLES=12
# Per-symbol HOLD alerts are noisy — keep OFF in steady state.
# Flip ON for a day or two during knob-tuning to observe rejections live.
TELEGRAM_HOLD_ALERT_ENABLED=false

# ----- Economic calendar awareness (Phase 9) ----------------
# Pulls high-impact USD macro events (FOMC, CPI, NFP, PCE, PPI, GDP,
# Retail Sales, ISM) once per 24h from ForexFactory's weekly JSON
# (no API key needed). Two safety behaviours:
#   1. Hard BLACKOUT: reject new entries within ECON_BLACKOUT_MIN
#      minutes of a matching event (existing SL/TP/trailing still runs).
#   2. SIZE MODIFIER: shrink notional by ECON_EVENT_SIZE_MULT for
#      +/-ECON_EVENT_WINDOW_H around the event so post-print whipsaw
#      doesn't blow small accounts.
# Firecrawl fallback kicks in if direct HTTP to faireconomy fails
# (ISP/corp firewall) — set FIRECRAWL_API_KEY and/or ECON_PREFER_FIRECRAWL=true.
ECON_CALENDAR_ENABLED=true
ECON_CALENDAR_REFRESH_HOURS=24
ECON_BLACKOUT_MIN=30
ECON_EVENT_WINDOW_H=2.0
ECON_EVENT_SIZE_MULT=0.5
ECON_TRACK_CURRENCIES=USD
ECON_TRACK_IMPACT=High
ECON_PREFER_FIRECRAWL=false
FIRECRAWL_API_KEY=
# Warn on Telegram when a matching event is within this many hours.
# Dedup'd per-boot: restart to re-arm warnings for the same event.
ECON_EVENT_WARN_AHEAD_H=2.0
